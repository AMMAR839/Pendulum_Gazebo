<?xml version="1.0"?>
<robot name="linear_inverted_pendulum" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:property name="PI" value="3.141592653589793"/>

  <!-- Manual LIP01 values used here:
       rail travel 78 cm, base 1000 mm x 350 mm, rod D8 x 400 mm, rod mass 200 g. -->
  <xacro:property name="travel" value="0.78"/>
  <xacro:property name="base_length" value="1.00"/>
  <xacro:property name="base_width" value="0.35"/>
  <xacro:property name="base_height" value="0.04"/>
  <xacro:property name="rail_length" value="0.90"/>
  <xacro:property name="rail_radius" value="0.005"/>
  <xacro:property name="rail_y" value="0.075"/>
  <xacro:property name="rail_z" value="0.10"/>
  <xacro:property name="pivot_z" value="0.50"/>
  <xacro:property name="cart_mass" value="1.20"/>
  <xacro:property name="cart_x" value="0.14"/>
  <xacro:property name="cart_y" value="0.18"/>
  <xacro:property name="cart_z" value="0.08"/>
  <xacro:property name="pendulum_length" value="0.40"/>
  <xacro:property name="pendulum_radius" value="0.004"/>
  <xacro:property name="pendulum_mass" value="0.20"/>
  <xacro:property name="pendulum_y_offset" value="-0.20"/>
  <xacro:property name="pendulum_y_offset_abs" value="0.20"/>
  <xacro:property name="pendulum_coupler_radius" value="0.006"/>

  <material name="black">
    <color rgba="0.02 0.025 0.03 1"/>
  </material>
  <material name="orange">
    <color rgba="1.0 0.42 0.04 1"/>
  </material>
  <material name="steel">
    <color rgba="0.72 0.72 0.70 1"/>
  </material>
  <material name="blue">
    <color rgba="0.08 0.32 0.95 1"/>
  </material>
  <material name="red">
    <color rgba="0.9 0.05 0.05 1"/>
  </material>

  <xacro:macro name="box_inertia" params="mass x y z">
    <inertia
      ixx="${mass / 12.0 * (y*y + z*z)}" ixy="0" ixz="0"
      iyy="${mass / 12.0 * (x*x + z*z)}" iyz="0"
      izz="${mass / 12.0 * (x*x + y*y)}"/>
  </xacro:macro>

  <xacro:macro name="cylinder_z_inertia" params="mass radius length">
    <inertia
      ixx="${mass / 12.0 * (3.0*radius*radius + length*length)}" ixy="0" ixz="0"
      iyy="${mass / 12.0 * (3.0*radius*radius + length*length)}" iyz="0"
      izz="${0.5 * mass * radius * radius}"/>
  </xacro:macro>

  <link name="world"/>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0"/>
      <mass value="10.6"/>
      <xacro:box_inertia mass="10.6" x="${base_length}" y="${base_width}" z="${base_height}"/>
    </inertial>

    <visual name="base_plate">
      <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision name="base_plate_collision">
      <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>

    <visual name="front_linear_shaft">
      <origin xyz="0 ${rail_y} ${rail_z}" rpy="0 ${PI / 2.0} 0"/>
      <geometry>
        <cylinder radius="${rail_radius}" length="${rail_length}"/>
      </geometry>
      <material name="steel"/>
    </visual>
    <visual name="rear_linear_shaft">
      <origin xyz="0 ${-rail_y} ${rail_z}" rpy="0 ${PI / 2.0} 0"/>
      <geometry>
        <cylinder radius="${rail_radius}" length="${rail_length}"/>
      </geometry>
      <material name="steel"/>
    </visual>
    <visual name="timing_belt">
      <origin xyz="0 0 ${rail_z - 0.025}" rpy="0 0 0"/>
      <geometry>
        <box size="${rail_length} 0.018 0.012"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <visual name="left_limit_switch">
      <origin xyz="${-travel / 2.0 - 0.025} 0 ${rail_z}" rpy="0 0 0"/>
      <geometry>
        <box size="0.025 0.20 0.045"/>
      </geometry>
      <material name="red"/>
    </visual>
    <visual name="right_limit_switch">
      <origin xyz="${travel / 2.0 + 0.025} 0 ${rail_z}" rpy="0 0 0"/>
      <geometry>
        <box size="0.025 0.20 0.045"/>
      </geometry>
      <material name="red"/>
    </visual>
  </link>

  <joint name="cart_slider" type="prismatic">
    <parent link="base_link"/>
    <child link="cart_link"/>
    <origin xyz="0 0 ${pivot_z}" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="${-travel / 2.0}" upper="${travel / 2.0}" effort="360.0" velocity="4.0"/>
    <dynamics damping="0.02" friction="0.0005"/>
  </joint>

  <link name="cart_link">
    <inertial>
      <origin xyz="0 0 -0.24" rpy="0 0 0"/>
      <mass value="${cart_mass}"/>
      <xacro:box_inertia mass="${cart_mass}" x="${cart_x}" y="${cart_y}" z="0.42"/>
    </inertial>

    <visual name="linear_bearing_carriage">
      <origin xyz="0 0 -0.38" rpy="0 0 0"/>
      <geometry>
        <box size="${cart_x} ${cart_y} ${cart_z}"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision name="linear_bearing_carriage_collision">
      <origin xyz="0 0 -0.38" rpy="0 0 0"/>
      <geometry>
        <box size="${cart_x} ${cart_y} ${cart_z}"/>
      </geometry>
    </collision>

    <visual name="pendulum_encoder_bracket">
      <origin xyz="0 0 -0.19" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.05 0.38"/>
      </geometry>
      <material name="steel"/>
    </visual>
    <collision name="pendulum_encoder_bracket_collision">
      <origin xyz="0 0 -0.19" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.05 0.38"/>
      </geometry>
    </collision>

    <visual name="encoder_hub">
      <origin xyz="0 0 0" rpy="${PI / 2.0} 0 0"/>
      <geometry>
        <cylinder radius="0.026" length="0.075"/>
      </geometry>
      <material name="orange"/>
    </visual>
  </link>

  <joint name="pendulum_hinge" type="continuous">
    <parent link="cart_link"/>
    <child link="pendulum_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.05" friction="0.0005"/>
  </joint>

  <link name="pendulum_link">
    <inertial>
      <origin xyz="0 ${pendulum_y_offset} ${-pendulum_length / 2.0}" rpy="0 0 0"/>
      <mass value="${pendulum_mass}"/>
      <xacro:cylinder_z_inertia mass="${pendulum_mass}" radius="${pendulum_radius}" length="${pendulum_length}"/>
    </inertial>
    <visual name="shaft_coupler_visual">
      <origin xyz="0 ${pendulum_y_offset / 2.0} 0" rpy="${PI / 2.0} 0 0"/>
      <geometry>
        <cylinder radius="${pendulum_coupler_radius}" length="${pendulum_y_offset_abs}"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision name="shaft_coupler_collision">
      <origin xyz="0 ${pendulum_y_offset / 2.0} 0" rpy="${PI / 2.0} 0 0"/>
      <geometry>
        <cylinder radius="${pendulum_coupler_radius}" length="${pendulum_y_offset_abs}"/>
      </geometry>
    </collision>
    <visual name="rod_visual">
      <origin xyz="0 ${pendulum_y_offset} ${-pendulum_length / 2.0}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${pendulum_radius}" length="${pendulum_length}"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision name="rod_collision">
      <origin xyz="0 ${pendulum_y_offset} ${-pendulum_length / 2.0}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${pendulum_radius}" length="${pendulum_length}"/>
      </geometry>
    </collision>
    <visual name="tip_marker">
      <origin xyz="0 ${pendulum_y_offset} ${-pendulum_length}" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.018"/>
      </geometry>
      <material name="orange"/>
    </visual>
  </link>

  <gazebo reference="base_link">
    <material>
      <ambient>0.02 0.025 0.03 1</ambient>
      <diffuse>0.02 0.025 0.03 1</diffuse>
    </material>
  </gazebo>
  <gazebo reference="cart_link">
    <material>
      <ambient>0.08 0.32 0.95 1</ambient>
      <diffuse>0.08 0.32 0.95 1</diffuse>
    </material>
  </gazebo>
  <gazebo reference="pendulum_link">
    <material>
      <ambient>0.90 0.05 0.05 1</ambient>
      <diffuse>0.90 0.05 0.05 1</diffuse>
    </material>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <joint_name>cart_slider</joint_name>
      <joint_name>pendulum_hinge</joint_name>
    </plugin>
    <plugin filename="gz-sim-apply-joint-force-system" name="gz::sim::systems::ApplyJointForce">
      <joint_name>cart_slider</joint_name>
    </plugin>
    <plugin filename="gz-sim-apply-joint-force-system" name="gz::sim::systems::ApplyJointForce">
      <joint_name>pendulum_hinge</joint_name>
    </plugin>
  </gazebo>
</robot>
